# Deterministic secret для HMAC-маскировки. Без него запуск завершится ошибкой.
# Сгенерировать: openssl rand -hex 32
MASKFLOW_SECRET=CHANGE_ME

# Корпоративный прокси для Docker-сборки. Оставь пустым если прокси не нужен.
# Альтернатива: Docker Desktop → Settings → Resources → Proxies → Use system proxy.
# Пример: HTTP_PROXY=http://proxy.corp.example.com:8080
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Runtime data root. Docker uses /data, local development can use ./data.
# Внутри него создаются configs, jobs, reports, tmp, models, cache, reversible.
MASKFLOW_DATA_DIR=data

# Уровень логирования (DEBUG / INFO / WARNING / ERROR)
MASKFLOW_LOG_LEVEL=INFO

# Host/port для API и Web UI
MASKFLOW_API_HOST=127.0.0.1
MASKFLOW_API_PORT=3100

# YAML config used by CLI/Web/API. Docker paths must use forward slashes.
MASKFLOW_DEFAULT_CONFIG=configs/default.yaml

# Docker build extras.
# Use download,nlp for GLiNER/spaCy/Natasha.
# Use download,nlp,qwen for configs/examples/full.yaml or MASKFLOW_QWEN_ENABLED=true.
MASKFLOW_EXTRAS=

# Hugging Face token for private/gated models or higher API limits.
# Public models such as Qwen/Qwen2.5-Coder-7B-Instruct usually work without it.
# Keep this as a runtime env variable; do not pass it as a Docker build arg.
HF_TOKEN=

# Включает NLP pipeline поверх regex-детекторов. Для маскирования NLP-сущностей
# в YAML также должны быть включены rules: person/organization/location/address.
MASKFLOW_NLP_ENABLED=false

# Разрешает автоматическое скачивание моделей в ${MASKFLOW_DATA_DIR}/models.
# Включайте только там, где разрешен outbound access к model registries.
MASKFLOW_NLP_AUTO_DOWNLOAD=false

# GLiNER zero-shot NER provider. Требует Docker/uv extra: download,nlp.
MASKFLOW_GLINER_ENABLED=false

# Hugging Face model id для GLiNER.
MASKFLOW_GLINER_MODEL=urchade/gliner_multi-v2.1

# Абсолютный путь или путь относительно ${MASKFLOW_DATA_DIR}/models.
# Пустое значение оставляет путь под управлением YAML/default path.
MASKFLOW_GLINER_MODEL_PATH=

# Устройство инференса GLiNER: cpu, cuda, cuda:0 и т.п.
MASKFLOW_GLINER_DEVICE=cpu

# spaCy provider. При auto_download=true модель будет скачана в data/models/spacy.
MASKFLOW_SPACY_ENABLED=false

# Имя spaCy model/package.
MASKFLOW_SPACY_MODEL=ru_core_news_lg

# Абсолютный путь, installed package name или путь относительно data/models.
# Пустое значение оставляет путь под управлением YAML/default package name.
MASKFLOW_SPACY_MODEL_PATH=

# Natasha provider для русского языка. Не требует отдельной model_path.
MASKFLOW_NATASHA_ENABLED=false

# Optional Qwen verifier. Requires Docker/uv extra: qwen.
MASKFLOW_QWEN_ENABLED=false

# Hugging Face model id для optional Qwen verifier.
MASKFLOW_QWEN_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# Абсолютный путь или путь относительно ${MASKFLOW_DATA_DIR}/models.
# Пустое значение оставляет путь под управлением YAML/default path.
MASKFLOW_QWEN_MODEL_PATH=

# Устройство инференса Qwen: cpu, cuda, cuda:0 и т.п.
MASKFLOW_QWEN_DEVICE=cpu

# Ключ Fernet для reversible_mapping. Включается, только если в YAML стоит
# reversible_mapping.enabled: true. Получить ключ: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASKFLOW_REVERSIBLE_KEY=YOUR_TOKEN
