# Detereministic secret для HMAC-маскировки. Без него запуск завершится ошибкой.
# Сгенерировать: openssl rand -hex 32
MASKFLOW_SECRET=CHANGE_ME

# Уровень логирования (DEBUG / INFO / WARNING / ERROR)
MASKFLOW_LOG_LEVEL=INFO

# Ключ Fernet для reversible_mapping. Включается, только если в YAML стоит
# reversible_mapping.enabled: true. Получить ключ: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASKFLOW_REVERSIBLE_KEY=YOUR_TOKEN
